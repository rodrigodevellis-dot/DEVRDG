# Configurações do Google Cloud Document AI

# ID do seu projeto no Google Cloud
GCP_PROJECT_ID=seu-projeto-id

# Localização do processador (us, eu, asia-northeast1, etc)
DOCUMENTAI_LOCATION=us

# ID do processador Document AI
# Obtenha em: https://console.cloud.google.com/ai/document-ai/processors
DOCUMENTAI_PROCESSOR_ID=seu-processor-id

# Caminho para o arquivo de credenciais (service account key)
GOOGLE_APPLICATION_CREDENTIALS=/caminho/para/credentials.json

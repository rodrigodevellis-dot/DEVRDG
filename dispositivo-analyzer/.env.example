# Database
DATABASE_URL=postgresql://dispositivo:dispositivo@localhost:5432/dispositivo

# LLM Provider (litellm-compatible)
LLM_PROVIDER=anthropic
LLM_MODEL=claude-opus-4-7
LLM_API_KEY=

# Optional: alternative providers
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-5.4
# LLM_API_KEY=...

# Optional: local model via vLLM/Ollama
# LLM_PROVIDER=openai
# LLM_BASE_URL=http://localhost:8000/v1
# LLM_API_KEY=dummy

# Logging
LOG_LEVEL=INFO

# Application
APP_HOST=127.0.0.1
APP_PORT=8000

# Sensitive data handling
ALLOW_EXTERNAL_LLM_DEFAULT=false
